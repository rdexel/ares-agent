{
  "mcpServers": {
    "gmail": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "tsx",
        "/ABSOLUTE/PATH/TO/Hubspot/gmail-mcp/src/server.ts"
      ]
    },
    "google-drive": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gdrive"],
      "env": {
        "GDRIVE_OAUTH_PATH": "/ABSOLUTE/PATH/TO/credentials.json",
        "GDRIVE_CREDENTIALS_PATH": "/Users/YOU/.config/google-drive-mcp/tokens.json"
      }
    },
    "google-calendar": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@cocal/google-calendar-mcp"],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "/ABSOLUTE/PATH/TO/credentials.json",
        "GOOGLE_CALENDAR_MCP_TOKEN_PATH": "/Users/YOU/.config/google-calendar-mcp/tokens.json"
      }
    },
    "hubspot": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@hubspot/mcp-server"],
      "env": {
        "PRIVATE_APP_ACCESS_TOKEN": "YOUR_HUBSPOT_PRIVATE_APP_TOKEN"
      }
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    }
  }
}
